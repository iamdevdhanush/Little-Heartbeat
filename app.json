{
  "expo": {
    "name": "Little Heartbeat",
    "slug": "little-heartbeat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "littleheartbeat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFE4EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.littleheartbeat.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Little Heartbeat needs your location to find nearby hospitals and provide safety alerts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Little Heartbeat uses your location to send emergency alerts to your contacts.",
        "NSContactsUsageDescription": "Little Heartbeat needs access to your contacts to set up emergency contacts."
      }
    },
    "android": {
      "package": "com.littleheartbeat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "SEND_SMS",
        "READ_CONTACTS",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "single",
      "meta": {
        "themeColor": "#E8517A",
        "description": "AI-powered pregnancy safety companion with real-time emergency alerts and health tracking"
      },
      "pointer": "grab",
      "backgroundColor": "#FFF8FA"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFE4EE",
          "dark": {
            "backgroundColor": "#1a1a1a"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Little Heartbeat to use your location to find nearby hospitals and send emergency alerts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "little-heartbeat-app"
      }
    }
  }
}
