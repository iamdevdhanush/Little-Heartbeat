# Render auto-injects DATABASE_URL from the PostgreSQL add-on
DATABASE_URL=postgresql://user:password@localhost:5432/little_heartbeat
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=./uploads
CORS_ORIGINS=https://your-app.vercel.app
TESSERACT_CMD=/usr/bin/tesseract
