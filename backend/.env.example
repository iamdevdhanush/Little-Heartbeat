# =============================================================================
# Little Heartbeat — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Environment -----------------------------------------------------------
# Set to "development" for detailed error messages in API responses.
# Set to "production" to suppress internal error details.
ENVIRONMENT=development

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string.
# Schema: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# Local development (Docker):
#   postgresql+asyncpg://postgres:dev@localhost:5432/little_heartbeat
#
# Neon (serverless free tier):
#   postgresql+asyncpg://<user>:<password>@<region>.pooler.supabase.com:5432/neondb
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/little_heartbeat

# --- Authentication ---------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars-long

# JWT signing algorithm. Do not change unless you understand the implications.
ALGORITHM=HS256

# Number of days before the access token expires.
#   - Development: 30 (fewer logins during debugging)
#   - Production:  7 (balance between UX and security)
ACCESS_TOKEN_EXPIRE_DAYS=30

# --- AI (Gemini) ------------------------------------------------------------
# Get your API key: https://aistudio.google.com/apikey
# The free tier (60 requests/minute) is sufficient for MVP-scale traffic.
GEMINI_API_KEY=your-gemini-api-key-here

# --- Web Push Notifications (VAPID) -----------------------------------------
# Generate a key pair with:
#   python -c "from pywebpush import generate_vapid_keys; import json; print(json.dumps(generate_vapid_keys(), indent=2))"
#
# The public key is sent to the browser so it can subscribe to push events.
# The private key signs outgoing push messages — keep it secret.
VAPID_PUBLIC_KEY=change-me-to-your-vapid-public-key
VAPID_PRIVATE_KEY=change-me-to-your-vapid-private-key

# --- Email (Resend) ---------------------------------------------------------
# Sign up: https://resend.com
# Free tier: 3,000 emails/month — enough for partner invitations and SOS alerts.
RESEND_API_KEY=re_your-resend-api-key

# The "from" address for all outgoing emails.
RESEND_FROM_ADDRESS=noreply@littleheartbeat.app

# --- Frontend ---------------------------------------------------------------
# Used for CORS headers and email deep links.
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
